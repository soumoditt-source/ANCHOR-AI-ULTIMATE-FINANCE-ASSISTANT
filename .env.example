# ─── Anchor AI Wealth OS — Environment Variables ─────────────────────────────
# Copy this file to `.env` and fill in your own keys.
# NEVER commit your actual .env file to version control.
#
# Add these keys as Vercel Environment Variables under:
# Vercel Dashboard → Your Project → Settings → Environment Variables

# ── Core AI Engine ─────────────────────────────────────────────────────────────
# Google Gemini (required) — powers Andy AI chat, document scan & analysis
# Get yours free: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Market Data ────────────────────────────────────────────────────────────────
# Finnhub (optional) — live stock quotes (AAPL, NVDA, etc.)
# Free tier: 60 req/min at https://finnhub.io/
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# CoinGecko (optional) — live crypto prices (BTC, ETH, SOL)
# Free tier available at https://www.coingecko.com/en/api
VITE_COINGECKO_API_KEY=your_coingecko_api_key_here

# ── News & Intelligence ────────────────────────────────────────────────────────
# NewsData.io (optional) — live financial news feed in Concierge/Market
# Free tier: 200 req/day at https://newsdata.io/
VITE_NEWSDATA_API_KEY=your_newsdata_api_key_here

# ── Currency Conversion ────────────────────────────────────────────────────────
# ExchangeRate-API (optional) — live FX rates for 12 supported currencies
# Free: 1500 req/month at https://www.exchangerate-api.com/
VITE_EXCHANGERATE_API_KEY=your_exchangerate_api_key_here

# ── Alternative AI Providers (optional) ───────────────────────────────────────
# OpenRouter — fallback LLM routing layer
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq — ultra-fast LLaMA inference (fallback)
VITE_GROQ_API_KEY=your_groq_api_key_here

# ── Auth / Persistence ─────────────────────────────────────────────────────────
# Supabase — user auth & saved financial data (optional, falls back to localStorage)
# Create free project: https://supabase.com/
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
